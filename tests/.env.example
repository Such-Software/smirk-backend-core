# Integration-test configuration (L1, fundless).
#
# Set TEST_DATABASE_URL to a throwaway Postgres database; the harness runs the
# migrations into it and exercises the real router + db layer. With it unset,
# integration tests self-skip and only the in-crate unit tests run.
#
# The harness sets its own deterministic, NON-SENSITIVE test secrets (JWT/peppers)
# internally — do not put real secrets or funded wallet seeds here.
#
# Local example (socket auth):
#   createdb smirk_backend_core_test
#   TEST_DATABASE_URL="postgresql:///smirk_backend_core_test?host=/var/run/postgresql" cargo test
TEST_DATABASE_URL=
